model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Fact Orders","Dim Employees","Dim Customer","Dim Product","Dim Store","Dim Category","Dim UOM","Fact_Orders_Position","Fact Store","Fact Sales","Fact Sales Position","Main page Measure Table","Store Page measures"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'Fact Orders'
ref table 'Dim Employees'
ref table 'Dim Customer'
ref table 'Dim Product'
ref table 'Dim Store'
ref table 'Dim Category'
ref table 'Dim UOM'
ref table Fact_Orders_Position
ref table 'Fact Store'
ref table 'Fact Sales'
ref table 'Fact Sales Position'
ref table Calendar
ref table 'Main page Measure Table'
ref table Fact_Plans
ref table 'Store Page measures'

ref cultureInfo en-US

