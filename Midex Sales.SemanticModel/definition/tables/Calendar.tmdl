		summarizeBy: sum
		isNameInferred
		sourceColumn: [WeekNum]

		annotation SummarizationSetBy = Automatic

	partition Calendar = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    CALENDARAUTO(), 
				    "Year", YEAR ( [Date] ),
				    "Month Num", MONTH ( [Date] ),
				    "Month", FORMAT ( [Date], "MMMM" ),
				    "Month Short", FORMAT ( [Date], "MMM" ),
				    "Quarter", "Q" & FORMAT ( [Date], "Q" ),
				    "Year-Quarter", YEAR ( [Date] ) & "-Q" & FORMAT ( [Date], "Q" ),
				    "Year-Month", FORMAT ( [Date], "YYYY-MM" ),
				    "Weekday Num", WEEKDAY ( [Date], 2 ), 
				    "Week Name", FORMAT ( [Date], "dddd" ),
				    "WeekNum", WEEKNUM ( [Date], 2 )
				)
				```

	annotation PBI_Id = 1e5ce5fb25844aa2b4694905ff9b9442

